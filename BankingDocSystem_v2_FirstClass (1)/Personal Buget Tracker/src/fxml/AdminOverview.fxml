<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.budgettracker.controller.AdminOverviewController" spacing="15" style="-fx-padding: 20;">
    <Label text="Admin Dashboard" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
    <HBox spacing="20">
        <VBox style="-fx-border-color: #E0E0E0; -fx-padding: 20;">
            <Label text="Total Users" style="-fx-font-size: 12;"/>
            <Label fx:id="totalUsersLabel" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
        </VBox>
        <VBox style="-fx-border-color: #E0E0E0; -fx-padding: 20;">
            <Label text="Total Transactions" style="-fx-font-size: 12;"/>
            <Label fx:id="totalTransactionsLabel" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
        </VBox>
        <VBox style="-fx-border-color: #E0E0E0; -fx-padding: 20;">
            <Label text="System Income" style="-fx-font-size: 12;"/>
            <Label fx:id="totalIncomeLabel" text="0.00" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>
    <Label text="Users" style="-fx-font-size: 14;"/>
    <TableView fx:id="usersTable" prefHeight="300">
        <columns>
            <TableColumn text="Username" prefWidth="120"/>
            <TableColumn text="Email" prefWidth="150"/>
            <TableColumn text="Name" prefWidth="150"/>
        </columns>
    </TableView>
</VBox>
