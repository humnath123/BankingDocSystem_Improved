<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.budgettracker.controller.UserReportsController" spacing="15" style="-fx-padding: 20;">
    <Label text="Reports & Analytics" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
    <HBox spacing="20">
        <VBox style="-fx-border-color: #E0E0E0; -fx-padding: 15; -fx-border-radius: 4;" spacing="5">
            <Label text="Monthly Income" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
            <Label fx:id="monthlyIncomeLabel" text="0.00" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
        </VBox>
        <VBox style="-fx-border-color: #E0E0E0; -fx-padding: 15; -fx-border-radius: 4;" spacing="5">
            <Label text="Monthly Expense" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
            <Label fx:id="monthlyExpenseLabel" text="0.00" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #F44336;"/>
        </VBox>
        <VBox style="-fx-border-color: #E0E0E0; -fx-padding: 15; -fx-border-radius: 4;" spacing="5">
            <Label text="Monthly Savings" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
            <Label fx:id="monthlySavingsLabel" text="0.00" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
        </VBox>
    </HBox>
    <Label text="Category Breakdown" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
    <TableView fx:id="categoryTable" prefHeight="300">
        <columns>
            <TableColumn text="Category" fx:id="categoryColumn" prefWidth="150"/>
            <TableColumn text="Total Spent" fx:id="spentColumn" prefWidth="100"/>
            <TableColumn text="Percentage" fx:id="percentageColumn" prefWidth="100"/>
        </columns>
    </TableView>
</VBox>
