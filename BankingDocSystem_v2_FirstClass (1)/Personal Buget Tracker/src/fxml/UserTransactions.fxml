<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.budgettracker.controller.UserTransactionsController" spacing="15" style="-fx-padding: 20;">
    <Label text="Manage Transactions" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
    <HBox spacing="10">
        <Button text="Add Income" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" onAction="#handleAddIncome"/>
        <Button text="Add Expense" style="-fx-background-color: #F44336; -fx-text-fill: white;" onAction="#handleAddExpense"/>
        <Button text="Delete" style="-fx-background-color: #FF9800; -fx-text-fill: white;" onAction="#handleDelete"/>
        <Button text="Refresh" style="-fx-background-color: #2196F3; -fx-text-fill: white;" onAction="#handleRefresh"/>
    </HBox>
    <TableView fx:id="transactionsTable" prefHeight="400">
        <columns>
            <TableColumn text="ID" fx:id="idColumn" prefWidth="50"/>
            <TableColumn text="Date" fx:id="dateColumn" prefWidth="100"/>
            <TableColumn text="Category" fx:id="categoryColumn" prefWidth="120"/>
            <TableColumn text="Type" fx:id="typeColumn" prefWidth="80"/>
            <TableColumn text="Amount" fx:id="amountColumn" prefWidth="100"/>
            <TableColumn text="Note" fx:id="noteColumn" prefWidth="200"/>
        </columns>
    </TableView>
</VBox>
