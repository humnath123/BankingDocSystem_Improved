<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.budgettracker.controller.UserDashboardController">
    <top>
        <VBox style="-fx-background-color: #2196F3; -fx-padding: 15;" spacing="10">
            <HBox spacing="20" style="-fx-alignment: center-left;">
                <Label text="User Dashboard" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="userLabel" style="-fx-text-fill: white;"/>
                <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: white; -fx-text-fill: #2196F3;"/>
            </HBox>
        </VBox>
    </top>
    <left>
        <VBox style="-fx-background-color: #F5F5F5; -fx-border-color: #E0E0E0; -fx-padding: 15;" spacing="10">
            <Button text="Dashboard" style="-fx-min-width: 180;" onAction="#showDashboard"/>
            <Button text="Transactions" style="-fx-min-width: 180;" onAction="#showTransactions"/>
            <Button text="Budget" style="-fx-min-width: 180;" onAction="#showBudget"/>
            <Button text="Saving Goals" style="-fx-min-width: 180;" onAction="#showSavingGoals"/>
            <Button text="Reports" style="-fx-min-width: 180;" onAction="#showReports"/>
            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentPane"/>
    </center>
</BorderPane>
